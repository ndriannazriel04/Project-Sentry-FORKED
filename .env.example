# ==============================================================================
# Project Sentinel Configuration
# ==============================================================================

# Database Configuration
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel_user
POSTGRES_PASSWORD=sentinel_secure_pass_change_me  # CHANGE THIS IN PRODUCTION!
DATABASE_URL=postgresql://sentinel_user:sentinel_secure_pass_change_me@postgres:5432/sentinel

# Logging
LOG_LEVEL=INFO

# LLM Configuration (Student 3)
LLM_API_KEY=your_gemini_or_gpt4_api_key_here
LLM_MODEL=gemini-pro  # Options: gemini-pro, gpt-4, claude-3-opus

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Security: API Keys & Secrets
STUDENT1_SECRET_KEY=generate-a-secure-random-key-here
STUDENT2_SECRET_KEY=generate-a-secure-random-key-here
STUDENT3_SECRET_KEY=generate-a-secure-random-key-here

# GeoIP & Threat Intel (Self-hosted)
GEOIP_DB_PATH=./infra/geoip-db/GeoLite2-City.mmdb
CTI_STIX_FEED_URL=https://cti.mycert.org.my/stix/feed  # Replace with actual MyCERT STIX feed
MITRE_ATTACK_DB_PATH=./infra/cti/mitre-attack.json

# Alert Thresholds
RISK_THRESHOLD_CRITICAL=80
RISK_THRESHOLD_HIGH=60
RISK_THRESHOLD_MEDIUM=40

# ChatOps (Optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Feature Flags
ENABLE_AI_ADVISOR=true
ENABLE_PLAYBOOK_AUTO_GENERATION=true
ENABLE_CHATOPS=false  # Set to true when ready
